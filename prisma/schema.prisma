// ตั้งค่า Prisma ใช้ PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role { 
  User
  Admin
}

model User {
  id       Int               @id @default(autoincrement())   
  email    String            @unique                         
  password String                                            
  prs      PurchaseRequest[]                                 
  role     Role              @default(User)                  
}

model PurchaseRequest {
  id          Int      @id @default(autoincrement()) 
  title       String   // ชื่อรายการที่ขอสั่งซื้อ
  department  String   // เพิ่มช่องเก็บแผนก
  amount      Float    // จำนวนเงิน 
  reason      String?  // เพิ่มช่องเก็บเหตุผล (ใส่ ? แปลว่าว่างได้)
  status      String   @default("Pending") 
  createdAt   DateTime @default(now()) // เก็บวันที่และเวลาที่สร้างใบ PR อัตโนมัติ
  userId      Int      
  user        User     @relation(fields: [userId], references: [id]) 
}