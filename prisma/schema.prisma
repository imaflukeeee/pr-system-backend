// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// ตั้งค่า Prisma ใช้ PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role { // enum สำหรับกำหนดประเภทผูใช้งาน
  USER
  ADMIN
}

// Table เก็บข้อมูลผู้ใช้งาน (สำหรับ Login)
model User {
  id       Int           @id @default(autoincrement())   // รหัสผู้ใช้ (ให้ระบบรันเลข 1, 2, 3... อัตโนมัติ)
  email    String        @unique                         // อีเมล (บังคับว่าห้ามสมัครซ้ำ)
  password String                                        // Password
  prs      PurchaseRequest[]                             // 1 User สามารถออก PR ได้หลายใบ
  role     Role          @default(USER)                  // กำหนดค่าเริ่มต้น Default ให้เป็น User
}

model PurchaseRequest {
  id      Int           @id @default(autoincrement())  // รหัสการสั่งซื้อ (Run No. อัตโนมัติ)
  title   String                                         // ชื่อรายการที่ขอสั่งซื้อ
  amount  Float                                          // จำนวนเงิน (ใช้ Float เก็บตัวเลขแบบทศนิยม)
  status  String        @default("Pending")              // สถานะการสั่งซื้อ (ถ้าไม่ได้ระบุให้ขึ้นเป็นรอดำเนินการ "Pending" รอดำเนินการ)
  userId  Int                                            // เก็บ User ที่ขอเบิก
  user     User     @relation(fields: [userId], references: [id]) // Relation to User model , userId คือ foreign key ที่อ้างอิงไปที่ User.id
}